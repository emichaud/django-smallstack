#!/bin/bash
# Pre-deploy hook: ensure volume directories exist with correct ownership
# on all remote hosts. Runs locally but SSHes to each KAMAL_HOSTS server.
#
# The container runs as non-root (USER app, uid 1000). Docker bind mounts
# create host dirs as root by default, so the app user can't write to them.
# This hook fixes that before the container starts.

# Extract volume host paths from deploy.yml
# Matches the host side of volume mounts (before the colon)
VOLUME_DIRS=$(ruby -ryaml -e '
  config = YAML.load_file("config/deploy.yml")
  (config["volumes"] || []).each do |v|
    puts v.split(":").first
  end
')

if [ -z "$VOLUME_DIRS" ]; then
  echo "No volumes found, skipping permission fix."
  exit 0
fi

# Convert newline-separated paths to a space-separated string
VOLUME_LIST=$(echo "$VOLUME_DIRS" | tr '\n' ' ')

# KAMAL_HOSTS is set by Kamal with the list of target hosts
for HOST in $(echo "$KAMAL_HOSTS" | tr ',' ' '); do
  echo "Fixing volume permissions on $HOST..."
  ssh root@"$HOST" "for dir in $VOLUME_LIST; do mkdir -p \"\$dir\" && chown -R 1000:1000 \"\$dir\"; done"
done

# ── Optional: open a maintenance window covering the deploy ────────────────────
# Opt-in via MAINTENANCE_ON_DEPLOY=true (see config/deploy.yml / .kamal/secrets).
# This marks the container-swap downtime as planned so the status page reads
# "Under maintenance" (not "Down") and the SLA calc excludes it. The old
# container is still serving here, and the SQLite DB lives on a shared volume,
# so the window written now persists across the swap.
#
# No separate token is needed: we reach the live container over the SSH channel
# Kamal already authenticates, via `kamal app exec`. The window is BOUNDED
# (--minutes), so if the deploy aborts and post-deploy never runs, it self-heals
# when the window expires. post-deploy closes it on success.
if [ "${MAINTENANCE_ON_DEPLOY}" = "true" ]; then
  MAINT_MINUTES="${MAINTENANCE_WINDOW_MINUTES:-15}"
  echo "Opening ${MAINT_MINUTES}m maintenance window for deploy ${KAMAL_VERSION:-}..."
  kamal app exec --reuse \
    "python manage.py maintenance open --minutes ${MAINT_MINUTES} --title 'Deploy ${KAMAL_VERSION:-}'" \
    || echo "WARN: could not open maintenance window (continuing deploy)."
fi
