# Kamal Secrets Configuration
# ============================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to 'secrets' (same directory):
#    cp .kamal/secrets.example .kamal/secrets
#
# 2. Update all values below with your actual credentials
#
# 3. Verify .gitignore includes '.kamal/secrets' (it should by default)
#
# 4. Update config/deploy.yml with your server IP and domain
#
# 5. Deploy with: kamal deploy
#
# NEVER commit the 'secrets' file to version control!

# ===========================================
# REQUIRED
# ===========================================

# Django secret key - MUST be unique for production
# Generate at: https://djecrety.ir/
SECRET_KEY=change-me-to-a-long-random-string

# Allowed hosts (comma-separated, no spaces)
# Include: your domain(s), www subdomain, server IP, localhost
# IMPORTANT: The trailing * is required for kamal-proxy health checks
# (kamal-proxy uses container IDs as HOST headers internally)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,YOUR_SERVER_IP,localhost,127.0.0.1,*

# CSRF trusted origins (required for HTTPS behind proxy)
# Must include https:// prefix for each origin
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ===========================================
# OPTIONAL
# ===========================================

# Registry password - only needed if using an authenticated Docker registry
# The default local registry (localhost:5555) does NOT require this
# Uncomment if using Docker Hub, GitHub Container Registry, etc.
# KAMAL_REGISTRY_PASSWORD=your-registry-password

# ===========================================
# DEPLOYMENT CHECKLIST
# ===========================================
#
# Before first deploy:
# [ ] VPS has Docker installed (kamal setup handles this)
# [ ] SSH access configured (ssh root@YOUR_SERVER_IP works)
# [ ] Domain DNS points to YOUR_SERVER_IP
# [ ] Docker Desktop running locally (for local registry)
#
# First deploy:
#   kamal setup    # Installs Docker on VPS, starts registry
#   kamal deploy   # Builds and deploys your app
#
# Subsequent deploys:
#   kamal deploy   # That's it!
#
# Useful commands:
#   kamal app logs              # View application logs
#   kamal app exec 'command'    # Run command in container
#   kamal rollback              # Rollback to previous version
