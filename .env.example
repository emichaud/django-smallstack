# Django SmallStack - Environment Configuration
# Copy this file to .env and update the values

# ===========================================
# REQUIRED SETTINGS
# ===========================================

# Django secret key - CHANGE THIS to a random string!
# Generate one at: https://djecrety.ir/
SECRET_KEY=change-me-to-a-random-secret-key

# Settings module
# Use "config.settings.development" for local development
# Use "config.settings.production" for Docker/production
DJANGO_SETTINGS_MODULE=config.settings.development

# Allowed hosts (comma-separated, required for production)
ALLOWED_HOSTS=localhost,127.0.0.1

# ===========================================
# DATABASE (Production/Docker)
# ===========================================

# SQLite database path (Docker uses /data/db.sqlite3)
DATABASE_PATH=/data/db.sqlite3

# Media files directory
MEDIA_ROOT=/app/media

# ===========================================
# AUTO-CREATE SUPERUSER (Docker)
# ===========================================
# Set these to automatically create an admin user on first Docker startup

# DJANGO_SUPERUSER_USERNAME=admin
# DJANGO_SUPERUSER_PASSWORD=your-secure-password
# DJANGO_SUPERUSER_EMAIL=admin@example.com

# ===========================================
# LOCAL DEVELOPMENT SUPERUSER
# ===========================================
# Used by "make dev-superuser" for local development

DEV_SUPERUSER_USERNAME=admin
DEV_SUPERUSER_PASSWORD=change-me-for-dev

# ===========================================
# HTTPS SETTINGS (Production)
# ===========================================
# Enable these when using HTTPS (behind a reverse proxy)

SECURE_SSL_REDIRECT=false
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false

# ===========================================
# AUTH FEATURE FLAGS (Optional)
# ===========================================
# Control visibility of login/signup UI

# SMALLSTACK_LOGIN_ENABLED=True    # Set False to hide Login/Sign Up from topbar
# SMALLSTACK_SIGNUP_ENABLED=True   # Set False to hide Sign Up and 404 the URL

# ===========================================
# EMAIL SETTINGS (Optional)
# ===========================================
# Configure for password reset emails

# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@example.com
# EMAIL_HOST_PASSWORD=your-email-password
# EMAIL_USE_TLS=true
